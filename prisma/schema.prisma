generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  // url = env("DATABASE_URL")
}

model Cart {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userEmail String   @unique
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}